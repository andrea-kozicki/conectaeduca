# .gitignore
# =====================================================
# ConectaEduca - arquivos ignorados pelo Git
# =====================================================


# =====================================================
# Segredos, credenciais e variáveis de ambiente
# =====================================================
.env
.env.*
!.env.example

# Arquivos que possam conter segredos locais
*.secret
*.secrets
*.credentials


# =====================================================
# Chaves, certificados e material criptográfico
# =====================================================
/keys/
/storage/keys/

*.pem
*.key
*.crt
*.csr
*.der
*.p12
*.pfx


# =====================================================
# Dependências PHP / Composer
# =====================================================
/vendor/


# =====================================================
# Pacotes, backups e artefatos gerados
# =====================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

/_arquivados/
/_backup_mvc_*/


# =====================================================
# Logs, cache e temporários
# =====================================================
*.log
*.tmp
*.temp
*.cache
*.bak
*.old
*.orig
*.swp
*.swo
*~

/storage/logs/*
!/storage/logs/.gitkeep

/storage/cache/*
!/storage/cache/.gitkeep

/cache/
/tmp/
/sessions/


# =====================================================
# Relatórios de cobertura e PHPUnit
# =====================================================
/coverage/
.phpunit.result.cache
.phpunit.cache/


# =====================================================
# Banco local
# =====================================================
*.sqlite
*.sqlite3
*.db


# =====================================================
# Uploads e arquivos enviados por usuários
# =====================================================
/uploads/
/public/uploads/


# =====================================================
# Arquivos de sistema operacional
# =====================================================
.DS_Store
Thumbs.db
desktop.ini


# =====================================================
# IDE / Editor
# =====================================================
.vscode/
.idea/
*.iml


# =====================================================
# Código legado / material fora do projeto principal
# =====================================================
/legado/


# =====================================================
# Arquivos sensíveis ou de debug
# =====================================================
phpinfo.php
**/phpinfo.php